  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#7d84b8", "fontStyle": "italic" }
    },
    {
      "name": "Doc comment",
      "scope": ["comment.block.documentation", "comment.documentation"],
      "settings": { "foreground": "#5a6088", "fontStyle": "italic" }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.conditional",
        "storage.type",
        "storage.modifier",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.operator.delete"
      ],
      "settings": { "foreground": "#ffc21f" }
    },
    {
      "name": "Loop / exception keyword (vim Repeat/Exception)",
      "scope": [
        "keyword.control.loop",
        "keyword.control.repeat",
        "keyword.control.exception",
        "keyword.control.trycatch",
        "keyword.control.flow.exception"
      ],
      "settings": { "foreground": "#b9dcff" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.separator.operator"],
      "settings": { "foreground": "#ffc21f" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly"
      ],
      "settings": { "foreground": "#f8f8f8" }
    },
    {
      "name": "String",
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#e8e6de" }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape", "constant.other.placeholder"],
      "settings": { "foreground": "#2f7bff" }
    },
    {
      "name": "Number / boolean / char / language constant (vim Constant #2f7bff)",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.character",
        "constant.other.symbol"
      ],
      "settings": { "foreground": "#2f7bff" }
    },
    {
      "name": "Constant identifier (vim rubyconstant #8fb4ff)",
      "scope": [
        "variable.other.constant",
        "entity.name.constant",
        "support.constant",
        "constant.other.constant"
      ],
      "settings": { "foreground": "#8fb4ff" }
    },
    {
      "name": "Function / method",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "meta.function-call support.function"
      ],
      "settings": { "foreground": "#b9dcff" }
    },
    {
      "name": "Class / type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class",
        "support.type",
        "entity.name.type.class"
      ],
      "settings": { "foreground": "#b9dcff" }
    },
    {
      "name": "Interface / namespace",
      "scope": ["entity.name.type.interface", "entity.name.namespace"],
      "settings": { "foreground": "#b9dcff" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other.readwrite", "meta.definition.variable"],
      "settings": { "foreground": "#f8f8f8" }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": { "foreground": "#0a3d91" }
    },
    {
      "name": "Property / field",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "variable.other.member",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#0a3d91" }
    },
    {
      "name": "Instance / language variable",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.other.instance"
      ],
      "settings": { "foreground": "#0a3d91" }
    },
    {
      "name": "Built-in / support variable (vim Identifier #c9cbd6)",
      "scope": ["support.variable", "variable.other.readwrite.global"],
      "settings": { "foreground": "#c9cbd6" }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation",
        "meta.annotation"
      ],
      "settings": { "foreground": "#b07400" }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#9fd0ff" }
    },
    {
      "name": "Tag attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#9fd0ff" }
    },
    {
      "name": "HTML/XML entity",
      "scope": ["constant.character.entity", "constant.character.entity.html"],
      "settings": { "foreground": "#2f7bff" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": { "foreground": "#a8863a" }
    },
    {
      "name": "CSS value",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css",
        "constant.numeric.css"
      ],
      "settings": { "foreground": "#2f7bff" }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#b9dcff" }
    },
    {
      "name": "CSS function",
      "scope": ["support.function.misc.css", "support.function.css"],
      "settings": { "foreground": "#b07400" }
    },
    {
      "name": "Regexp character class",
      "scope": [
        "constant.other.character-class.regexp",
        "constant.character.class.regexp"
      ],
      "settings": { "foreground": "#d9a441" }
    },
    {
      "name": "Regexp meta / anchor",
      "scope": [
        "keyword.control.anchor.regexp",
        "keyword.operator.quantifier.regexp",
        "punctuation.definition.group.regexp"
      ],
      "settings": { "foreground": "#ffc21f" }
    },
    {
      "name": "Regexp quoted",
      "scope": ["punctuation.definition.character-class.regexp"],
      "settings": { "foreground": "#d9a441" }
    },
    {
      "name": "Markup heading",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#b9dcff", "fontStyle": "bold" }
    },
    {
      "name": "Markup bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#b07400", "fontStyle": "bold" }
    },
    {
      "name": "Markup italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#b07400", "fontStyle": "italic" }
    },
    {
      "name": "Markup link",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#2f7bff" }
    },
    {
      "name": "Markup code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#e8e6de" }
    },
    {
      "name": "Markup quote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#81818a", "fontStyle": "italic" }
    },
    {
      "name": "Markup inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#8fb4ff" }
    },
    {
      "name": "Markup deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#ffc21f" }
    },
    {
      "name": "YAML key",
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#b9dcff" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#b9dcff" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#f8f8f8", "fontStyle": "" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#81818a", "fontStyle": "strikethrough" }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#0a3d91",
    "property": "#0a3d91",
    "variable.constant": "#8fb4ff",
    "variable.defaultLibrary": "#c9cbd6",
    "function.defaultLibrary": "#b9dcff",
    "class": "#b9dcff",
    "interface": "#b9dcff",
    "enum": "#b9dcff",
    "enumMember": "#8fb4ff",
    "type": "#b9dcff",
    "namespace": "#b9dcff",
    "decorator": "#b07400",
    "*.declaration": { "fontStyle": "" }
  }
}
