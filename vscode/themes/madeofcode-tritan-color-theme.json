  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#c050c2", "fontStyle": "italic" }
    },
    {
      "name": "Doc comment",
      "scope": ["comment.block.documentation", "comment.documentation"],
      "settings": { "foreground": "#a046a2", "fontStyle": "italic" }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.conditional",
        "storage.type",
        "storage.modifier",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.operator.delete"
      ],
      "settings": { "foreground": "#ff3854" }
    },
    {
      "name": "Loop / exception keyword (vim Repeat/Exception)",
      "scope": [
        "keyword.control.loop",
        "keyword.control.repeat",
        "keyword.control.exception",
        "keyword.control.trycatch",
        "keyword.control.flow.exception"
      ],
      "settings": { "foreground": "#00d3a0" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.separator.operator"],
      "settings": { "foreground": "#ff3854" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly"
      ],
      "settings": { "foreground": "#f8f8f8" }
    },
    {
      "name": "String",
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#4fd06a" }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape", "constant.other.placeholder"],
      "settings": { "foreground": "#ff7ab0" }
    },
    {
      "name": "Number / boolean / char / language constant (vim Constant #ff7ab0)",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.character",
        "constant.other.symbol"
      ],
      "settings": { "foreground": "#ff7ab0" }
    },
    {
      "name": "Constant identifier (vim rubyconstant #c7f06a)",
      "scope": [
        "variable.other.constant",
        "entity.name.constant",
        "support.constant",
        "constant.other.constant"
      ],
      "settings": { "foreground": "#c7f06a" }
    },
    {
      "name": "Function / method",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "meta.function-call support.function"
      ],
      "settings": { "foreground": "#00d3a0" }
    },
    {
      "name": "Class / type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class",
        "support.type",
        "entity.name.type.class"
      ],
      "settings": { "foreground": "#00d3a0" }
    },
    {
      "name": "Interface / namespace",
      "scope": ["entity.name.type.interface", "entity.name.namespace"],
      "settings": { "foreground": "#00d3a0" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other.readwrite", "meta.definition.variable"],
      "settings": { "foreground": "#f8f8f8" }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": { "foreground": "#e06a3a" }
    },
    {
      "name": "Property / field",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "variable.other.member",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#e06a3a" }
    },
    {
      "name": "Instance / language variable",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.other.instance"
      ],
      "settings": { "foreground": "#e06a3a" }
    },
    {
      "name": "Built-in / support variable (vim Identifier #a8c0a0)",
      "scope": ["support.variable", "variable.other.readwrite.global"],
      "settings": { "foreground": "#a8c0a0" }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation",
        "meta.annotation"
      ],
      "settings": { "foreground": "#ff9d33" }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#3fd0b0" }
    },
    {
      "name": "Tag attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#3fd0b0" }
    },
    {
      "name": "HTML/XML entity",
      "scope": ["constant.character.entity", "constant.character.entity.html"],
      "settings": { "foreground": "#ff7ab0" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": { "foreground": "#cf6a4c" }
    },
    {
      "name": "CSS value",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css",
        "constant.numeric.css"
      ],
      "settings": { "foreground": "#ff7ab0" }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#00d3a0" }
    },
    {
      "name": "CSS function",
      "scope": ["support.function.misc.css", "support.function.css"],
      "settings": { "foreground": "#ff9d33" }
    },
    {
      "name": "Regexp character class",
      "scope": [
        "constant.other.character-class.regexp",
        "constant.character.class.regexp"
      ],
      "settings": { "foreground": "#cf9f5a" }
    },
    {
      "name": "Regexp meta / anchor",
      "scope": [
        "keyword.control.anchor.regexp",
        "keyword.operator.quantifier.regexp",
        "punctuation.definition.group.regexp"
      ],
      "settings": { "foreground": "#ff3854" }
    },
    {
      "name": "Regexp quoted",
      "scope": ["punctuation.definition.character-class.regexp"],
      "settings": { "foreground": "#cf9f5a" }
    },
    {
      "name": "Markup heading",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#00d3a0", "fontStyle": "bold" }
    },
    {
      "name": "Markup bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#ff9d33", "fontStyle": "bold" }
    },
    {
      "name": "Markup italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#ff9d33", "fontStyle": "italic" }
    },
    {
      "name": "Markup link",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#ff7ab0" }
    },
    {
      "name": "Markup code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#4fd06a" }
    },
    {
      "name": "Markup quote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#81818a", "fontStyle": "italic" }
    },
    {
      "name": "Markup inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#c7f06a" }
    },
    {
      "name": "Markup deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#ff3854" }
    },
    {
      "name": "YAML key",
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#00d3a0" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#00d3a0" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#f8f8f8", "fontStyle": "" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#81818a", "fontStyle": "strikethrough" }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#e06a3a",
    "property": "#e06a3a",
    "variable.constant": "#c7f06a",
    "variable.defaultLibrary": "#a8c0a0",
    "function.defaultLibrary": "#00d3a0",
    "class": "#00d3a0",
    "interface": "#00d3a0",
    "enum": "#00d3a0",
    "enumMember": "#c7f06a",
    "type": "#00d3a0",
    "namespace": "#00d3a0",
    "decorator": "#ff9d33",
    "*.declaration": { "fontStyle": "" }
  }
}
