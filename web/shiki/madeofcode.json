{
  "name": "madeofcode",
  "type": "dark",
  "displayName": "madeofcode",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#090a1b",
    "editor.foreground": "#f8f8f8"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#c050c2", "fontStyle": "italic" } },
    { "scope": ["comment.block.documentation", "comment.documentation"], "settings": { "foreground": "#a046a2", "fontStyle": "italic" } },
    { "scope": ["keyword", "keyword.control", "keyword.control.conditional", "keyword.operator", "storage.type", "storage.modifier", "keyword.other"], "settings": { "foreground": "#ff3854" } },
    { "scope": ["keyword.control.loop", "keyword.control.repeat", "keyword.control.exception", "keyword.control.trycatch", "keyword.control.flow.exception"], "settings": { "foreground": "#6fd3ff" } },
    { "scope": ["string", "punctuation.definition.string"], "settings": { "foreground": "#8fff58" } },
    { "scope": ["constant.character.escape", "constant.other.placeholder"], "settings": { "foreground": "#0a9cff" } },
    { "scope": ["constant.numeric", "constant.language", "constant.language.boolean", "constant.character", "constant.other.symbol"], "settings": { "foreground": "#0a9cff" } },
    { "scope": ["variable.other.constant", "entity.name.constant", "support.constant"], "settings": { "foreground": "#00ffbc" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"], "settings": { "foreground": "#6fd3ff" } },
    { "scope": ["entity.name.type", "entity.name.class", "entity.other.inherited-class", "support.class", "support.type", "entity.name.namespace"], "settings": { "foreground": "#6fd3ff" } },
    { "scope": ["variable", "variable.other.readwrite", "meta.definition.variable"], "settings": { "foreground": "#f8f8f8" } },
    { "scope": ["variable.parameter", "variable.other.member", "variable.other.property", "variable.language.this", "meta.object-literal.key"], "settings": { "foreground": "#588aff" } },
    { "scope": ["support.variable", "variable.other.builtin"], "settings": { "foreground": "#99cf50" } },
    { "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator", "storage.type.annotation", "meta.annotation"], "settings": { "foreground": "#f1d950" } },
    { "scope": ["entity.name.tag", "punctuation.definition.tag", "entity.other.attribute-name"], "settings": { "foreground": "#45c1ea" } },
    { "scope": ["support.type.property-name.css", "meta.property-name.css"], "settings": { "foreground": "#cf6a4c" } },
    { "scope": ["string.regexp", "constant.other.character-class.regexp"], "settings": { "foreground": "#e9c062" } },
    { "scope": ["punctuation.separator", "punctuation.terminator", "meta.brace"], "settings": { "foreground": "#f8f8f8" } },
    { "scope": ["markup.heading", "entity.name.section"], "settings": { "foreground": "#6fd3ff", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "foreground": "#f1d950", "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "foreground": "#f1d950", "fontStyle": "italic" } },
    { "scope": ["markup.underline.link", "string.other.link"], "settings": { "foreground": "#0a9cff" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#8fff58" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#00ffbc" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#ff3854" } },
    { "scope": ["invalid.deprecated"], "settings": { "foreground": "#81818a" } }
  ]
}
